{
  "manifest_version": 3,
  "name": "Coursera Video Dubber",
  "version": "1.0",
  "description": "Dubs Coursera videos from English to French using Azure Cognitive Services",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://*.coursera.org/*",
    "https://*.youtube.com/*",
    "https://*.api.cognitive.microsoft.com/*",
    "https://*.tts.speech.microsoft.com/*",
    "https://api.cognitive.microsofttranslator.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.coursera.org/*",
        "https://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Coursera Dubber"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": []
}